*.py[cod]
*$py.class
*.so
*.pyd
*.pyo
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/

# ── C++ build artefacts ───────────────────────────────────────────────────────
*.o
*.a
*.lib
*.dll
*.dylib
cmake-build-*/
CMakeCache.txt
CMakeFiles/
Makefile
install_manifest.txt
