# ── Data (raw and large processed files) ─────────────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/shapefiles/*
!data/shapefiles/.gitkeep

# ── Output files ─────────────────────────────────────────────────────────────
outputs/maps/*
!outputs/maps/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
outputs/reports/*
!outputs/reports/.gitkeep

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.*
.venv/
venv/
env/
*.key
*.pem
secrets.yaml
config/secrets.yaml

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb~

# ── IDE / OS ─────────────────────────────────────────────────────────────────
